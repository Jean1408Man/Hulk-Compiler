// Corte 7 — Test ok_01: declaraciones válidas y referencias resueltas
// Esperado: análisis semántico OK, 1 función y 2 tipos registrados

function greet(name: String): String => "Hola " @ name;

type Animal(name) {
    name = name;
    speak() => print("...");
}

type Dog(name) inherits Animal(name) {
    speak() => print("Woof! I am " @ self.name);
}

let d = new Dog("Rex") in d.speak();
print(greet("mundo"));
